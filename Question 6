#include <iostream>
#include <cstring>
using namespace std;

class Employee {
    char *name;
    float salary;

public:
    Employee(const char *n, float s) {
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        salary = s;
        cout << "Constructor called\n";
    }

    void display() {
        cout << "Name: " << name << endl;
        cout << "Salary: " << salary << endl;
    }

    ~Employee() {
        delete[] name;
        cout << "Destructor called\n";
    }
};

int main() {
    Employee e1("hari", 25000);
    e1.display();

    return 0;
